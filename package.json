{
  "name": "activation-engine",
  "version": "1.0.0",
  "description": "Activation Engine backend foundation (Express + Sequelize + MySQL)",
  "main": "server.js",
  "engines": {
    "node": ">=22.12.0 <25",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test DB_DIALECT=sqlite DB_STORAGE=:memory: jest --detectOpenHandles --forceExit --runInBand"
  },
  "keywords": [
    "activation-engine",
    "nodejs",
    "express",
    "sequelize",
    "mysql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.11.3",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
