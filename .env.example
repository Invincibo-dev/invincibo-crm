NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://cv-pam.com
JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_EXPIRES_IN=8h
# Required only to create the very first administrator. Remove it after bootstrap.
ADMIN_BOOTSTRAP_TOKEN=replace_with_a_one_time_random_bootstrap_token

# Rate limits
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20

# mysql | sqlite
DB_DIALECT=mysql
DB_HOST=your_hostinger_mysql_host
DB_PORT=3306
DB_NAME=crm_db
DB_USER=your_hostinger_mysql_user
DB_PASSWORD=your_hostinger_mysql_password

# Used only when DB_DIALECT=sqlite
DB_STORAGE=./dev.sqlite

# Enable only for local bootstrap/dev. Keep false or unset in production.
DB_AUTO_SYNC=false

# WhatsApp Cloud API used by CRM follow-ups and Activation Engine modules
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_COOLDOWN_HOURS=6
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_BACKOFF_MS=1000
WHATSAPP_FOLLOWUP_MAX_ATTEMPTS=3

# Google People API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Tracking
TRACKING_BASE_URL=https://api.cv-pam.com
TRACKING_SECRET=replace_with_a_long_random_secret
TRACKING_TOKEN_TTL_SECONDS=2592000
TRACKING_DEST_ACTIVATION=https://cv-pam.com/activation
TRACKING_DEST_ONBOARDING=https://cv-pam.com/onboarding
TRACKING_DEST_PAYMENT=https://cv-pam.com/payment
TRACKING_DEST_DEFAULT=https://cv-pam.com

# Automation tuning
FOLLOWUP_CRON_ENABLED=false
ACTION_DEDUP_WINDOW_MS=90000
AT_RISK_CHUNK_SIZE=25
